@model FacultyFormViewModel
@{
    ViewData["Title"] = Model.Id is null ? "Новий факультет" : "Редагування факультету";
}

<h1 class="mb-4">@ViewData["Title"]</h1>

<partial name="_SuperAdminNavLinks" model="SuperAdminNavigation.FacultiesBack()"/>

<form asp-action="@(Model.Id is null ? "Create" : "Edit")" method="post">
    @Html.AntiForgeryToken()
    @if (Model.Id is not null)
    {
        <input type="hidden" asp-for="Id"/>
    }
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <div class="mb-3">
        <label asp-for="Name" class="form-label">Назва</label>
        <input asp-for="Name" class="form-control" maxlength="256"/>
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>
    <button type="submit" class="btn btn-primary">Зберегти</button>
    <a class="btn btn-link" asp-action="Index">Скасувати</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial"/>
}
