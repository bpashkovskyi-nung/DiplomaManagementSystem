@model PendingCheckpointListViewModel

<table class="table table-striped align-middle">
    <thead>
    <tr>
        <th>Студент</th>
        <th>Група</th>
        <th>Тема</th>
        <th>Робота</th>
        <th></th>
    </tr>
    </thead>
    <tbody>
    @if (!Model.Items.Any())
    {
        <tr>
            <td colspan="5" class="text-muted">@Model.EmptyMessage</td>
        </tr>
    }
    @foreach (PendingCheckpointItemViewModel item in Model.Items)
    {
        <tr>
            <td>@item.StudentFullName</td>
            <td>@item.StudyGroupName</td>
            <td>@(item.TopicTitle ?? "—")</td>
            <td>
                <partial name="_PendingStudentWorkLink" model="item.LatestStudentWork"/>
            </td>
            <td class="text-end text-nowrap">
                <partial name="_CheckpointReviewActions"
                         model="new CheckpointReviewActionsViewModel
                         {
                             DiplomaId = item.DiplomaId,
                             StudentFullName = item.StudentFullName,
                             FormAction = Model.FormAction,
                             RequiresDocumentFile = Model.RequiresDocumentFile,
                         }"/>
            </td>
        </tr>
    }
    </tbody>
</table>
