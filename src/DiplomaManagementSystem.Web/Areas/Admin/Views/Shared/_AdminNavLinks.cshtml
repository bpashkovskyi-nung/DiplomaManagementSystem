@model IReadOnlyList<AdminNavLink>

@if (Model.Count > 0)
{
    <p class="mb-3">
        @for (int i = 0; i < Model.Count; i++)
        {
            AdminNavLink link = Model[i];
            if (i > 0)
            {
                <text> · </text>
            }

            @if (link.RouteValues is null || link.RouteValues.Count == 0)
            {
                <a asp-area="Admin" asp-controller="@link.Controller" asp-action="@link.Action">@link.Text</a>
            }
            else
            {
                <a asp-area="Admin"
                   asp-controller="@link.Controller"
                   asp-action="@link.Action"
                   asp-all-route-data="@(new Dictionary<string, string>(link.RouteValues))">@link.Text</a>
            }
        }
    </p>
}
