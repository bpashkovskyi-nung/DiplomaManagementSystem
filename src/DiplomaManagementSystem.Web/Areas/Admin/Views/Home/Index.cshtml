@{
    ViewData["Title"] = AdminPageTitles.Home;
}

<h1 class="mb-4">@AdminPageTitles.Home</h1>

<partial name="_TempDataAlerts"/>

<div class="row g-3 justify-content-center">
    <div class="col-md-4">
        <div class="card h-100">
            <div class="card-body d-flex flex-column h-100">
                <h5 class="card-title">@AdminPageTitles.DefenceSessions</h5>
                <p class="card-text text-muted small flex-grow-1">Групи та студенти керуються в межах кожної сесії.</p>
                <a class="btn btn-primary align-self-start" asp-controller="DefenceSessions" asp-action="Index">Відкрити</a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100">
            <div class="card-body d-flex flex-column h-100">
                <h5 class="card-title">@AdminPageTitles.Employees</h5>
                <p class="card-text text-muted small flex-grow-1">Облікові записи викладачів для призначення керівником та рецензентом.</p>
                <a class="btn btn-primary align-self-start" asp-controller="Employees" asp-action="Index">Відкрити</a>
            </div>
        </div>
    </div>
</div>
