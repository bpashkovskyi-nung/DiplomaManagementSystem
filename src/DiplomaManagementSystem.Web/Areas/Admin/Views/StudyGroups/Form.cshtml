@model DiplomaManagementSystem.Web.Areas.Admin.Models.StudyGroupFormViewModel
@{
    ViewData["Title"] = Model.Id is null ? "Нова група" : "Редагування групи";
}

<h1 class="mb-1">@ViewData["Title"]</h1>
<p class="text-muted mb-4">@Model.SessionLabel</p>

<partial name="_AdminNavLinks" model="AdminNavigation.SessionContext(Model.DefenceSessionId)"/>

<form asp-action="@(Model.Id is null ? "Create" : "Edit")" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="DefenceSessionId"/>
    @if (Model.Id is not null)
    {
        <input type="hidden" asp-for="Id"/>
    }
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <div class="mb-3">
        <label asp-for="Name" class="form-label">Назва</label>
        <input asp-for="Name" class="form-control" maxlength="50"/>
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="SpecialtyId" class="form-label">Спеціальність</label>
        <select asp-for="SpecialtyId" class="form-select" asp-items="@(new SelectList(Model.SpecialtyOptions, nameof(StudyGroupSpecialtyOptionViewModel.Id), nameof(StudyGroupSpecialtyOptionViewModel.Label)))">
            <option value="">Оберіть спеціальність</option>
        </select>
        <span asp-validation-for="SpecialtyId" class="text-danger"></span>
        @if (Model.SpecialtyOptions.Count == 0)
        {
            <div class="form-text text-warning">Спочатку додайте спеціальність для кафедри сесії.</div>
        }
    </div>
    <div class="mb-3">
        <label asp-for="StudyForm" class="form-label">Форма навчання</label>
        <input asp-for="StudyForm" class="form-control" maxlength="128"/>
        <span asp-validation-for="StudyForm" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="Course" class="form-label">Курс</label>
        <input asp-for="Course" class="form-control" type="number" min="1" max="6"/>
        <span asp-validation-for="Course" class="text-danger"></span>
    </div>
    <button type="submit" class="btn btn-primary">Зберегти</button>
    <a class="btn btn-link" asp-controller="DefenceSessions" asp-action="Details" asp-route-id="@Model.DefenceSessionId">Скасувати</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial"/>
}
