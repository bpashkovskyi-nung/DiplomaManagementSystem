@model IReadOnlyList<SecretaryNavLink>

@if (Model.Count > 0)
{
    <p class="mb-3">
        @for (int i = 0; i < Model.Count; i++)
        {
            SecretaryNavLink link = Model[i];
            if (i > 0)
            {
                <text> · </text>
            }

            <a asp-area="Secretary" asp-controller="@link.Controller" asp-action="@link.Action">@link.Text</a>
        }
    </p>
}
