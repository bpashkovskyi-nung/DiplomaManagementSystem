@model TopicOrderViewModel
@{
    ViewData["Title"] = SecretaryPageTitles.TopicOrder;
}

<h1 class="mb-1">@ViewData["Title"]</h1>
<p class="text-muted mb-4">@Model.SessionLabel</p>

<partial name="_TempDataAlerts"/>

<partial name="_SecretaryNavLinks" model="SecretaryNavigation.DocumentsAndReports()"/>

<form asp-action="TopicOrder" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="SessionId"/>
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="row g-3 mb-3">
        <div class="col-md-4">
            <label asp-for="OrderNumber" class="form-label">№ наказу</label>
            <input asp-for="OrderNumber" class="form-control" maxlength="32"/>
            <span asp-validation-for="OrderNumber" class="text-danger"></span>
        </div>
        <div class="col-md-4">
            <label asp-for="Year" class="form-label">Рік</label>
            <input asp-for="Year" class="form-control" type="number" min="2000" max="2100"/>
            <span asp-validation-for="Year" class="text-danger"></span>
        </div>
    </div>

    <div class="mb-3">
        <label class="form-label">Групи</label>
        @if (!Model.StudyGroups.Any())
        {
            <p class="text-muted">У сесії немає груп.</p>
        }
        else
        {
            <div class="border rounded p-3">
                @foreach (TopicOrderStudyGroupOptionViewModel group in Model.StudyGroups)
                {
                    <div class="form-check">
                        <input class="form-check-input"
                               type="checkbox"
                               name="SelectedStudyGroupIds"
                               value="@group.Id"
                               id="group-@group.Id"
                               @(Model.SelectedStudyGroupIds.Contains(group.Id) ? "checked" : null)/>
                        <label class="form-check-label" for="group-@group.Id">
                            @group.Name
                            @if (group.Course is int course)
                            {
                                <span class="text-muted">(курс @course)</span>
                            }
                            else
                            {
                                <span class="text-warning">(курс не задано)</span>
                            }
                        </label>
                    </div>
                }
            </div>
        }
    </div>

    @if (Model.Warnings.Any())
    {
        <div class="alert alert-warning">
            <ul class="mb-0">
                @foreach (string warning in Model.Warnings)
                {
                    <li>@warning</li>
                }
            </ul>
        </div>
    }

    <p class="text-muted small">
        У наказ потрапляють лише студенти з <strong>затвердженою темою</strong> та <strong>підтвердженим керівником</strong>.
        Заголовок містить згадку про консультантів; окремого § про консультантів немає.
    </p>

    <button type="submit" class="btn btn-primary">Завантажити DOCX</button>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial"/>
}
